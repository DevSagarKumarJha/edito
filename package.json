{
  "name": "code-editor",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm -w server run dev\" \"npm -w client run dev\"",
    "dev:server": "npm -w server run dev",
    "dev:client": "npm -w client run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
