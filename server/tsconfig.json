{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "target": "es6",
    "lib": ["ES2023"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "outDir": "dist",
    "sourceMap": false,
    "rootDir": ".",
    "composite": true,
    "noEmit": false,
    "esModuleInterop": true,
  },
  "include": ["src", "index.ts"]
}