{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "outDir": "./dist",
    "rootDir": ".",
    "composite": true,
    "noEmit": false
  },
  "include": ["src", "index.ts"]
}
